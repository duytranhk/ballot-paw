{
  "name": "ballot-paw",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://duytranhk.github.io/ballot-paw",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "oxlint src && oxfmt --check && tsc -b && vite build",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "deploy": "gh-pages -d dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-ga4": "^2.1.0",
    "tailwindcss": "^4.2.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
